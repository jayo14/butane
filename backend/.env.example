# Django core
DJANGO_SETTINGS_MODULE=core.settings
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:3000

# Database
# Set DATABASE_URL for PostgreSQL (Neon, Render, etc.):
#   postgresql://user:password@host:5432/neondb?sslmode=require
# For Neon, use the pooler URL:
#   DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Leave empty to use the legacy DB_ENGINE / per-field config below.
DATABASE_URL=
# Legacy per-field config (used when DATABASE_URL is empty):
DB_ENGINE=sqlite
DB_NAME=db.sqlite3

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS (hardcoded in settings.py; override here to add more origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Celery / Redis (async tasks)
# Leave empty to run tasks synchronously (CELERY_TASK_ALWAYS_EAGER).
# Point at a Redis instance in production:
#   CELERY_BROKER_URL=redis://redis:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Feature flags
SCHOOL_ONBOARDING_ENABLED=false

# Cloudinary (image uploads)
# Get credentials from https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
